# SEG-07: espelho do /opt/radar/api/.env — documenta as variáveis SEM os valores.
# O .env real vive só no servidor (chmod 640, dono www-data) e NUNCA entra no git.

# PostgreSQL local do VPS (usuário/senha em /root/radar-info.txt)
DATABASE_URL=postgres://radar:SENHA@localhost:5432/radar

# IA local (base eterna e fallback) — Ollama no próprio VPS
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434
AI_MODEL_FAST=qwen3:8b
AI_MODEL_ADVANCED=qwen3:14b

# IA remota opcional (cadeia liga sozinha se a chave existir) — Groq/NVIDIA Build etc.
AI_REMOTE_BASE_URL=https://api.groq.com/openai/v1
AI_REMOTE_API_KEY=
AI_REMOTE_MODEL_FAST=qwen/qwen3-32b
AI_REMOTE_MODEL_ADVANCED=llama-3.3-70b-versatile

# Busca web (fonte A de anúncios) — free tier 2k/mês
BRAVE_API_KEY=

# Token interno das rotas de escrita (ingerir/varrer/extrair/requalificar por API)
MOTOR_TOKEN=

# Painel do corretor (SEG-01/05): SEM senha aqui o painel NEM EXISTE (404).
# PAINEL_SECRET mantém as sessões válidas entre deploys (opcional).
PAINEL_SENHA=
PAINEL_SECRET=
