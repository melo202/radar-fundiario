# SEG-07: espelho do /opt/radar/api/.env — documenta as variáveis SEM os valores.
# O .env real vive só no servidor (chmod 640, dono www-data) e NUNCA entra no git.

# PostgreSQL local do VPS (usuário/senha em /root/radar-info.txt)
DATABASE_URL=postgres://radar:SENHA@localhost:5432/radar

# IA local (base eterna e fallback) — Ollama no próprio VPS
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434
AI_MODEL_FAST=qwen3:8b
AI_MODEL_ADVANCED=qwen3:14b

# IA remota opcional (cadeia liga sozinha se a chave existir) — Groq/NVIDIA Build etc.
AI_REMOTE_BASE_URL=https://api.groq.com/openai/v1
AI_REMOTE_API_KEY=
AI_REMOTE_MODEL_FAST=qwen/qwen3-32b
AI_REMOTE_MODEL_ADVANCED=llama-3.3-70b-versatile

# IA remota degrau 2 (NVIDIA Build free endpoint — cadeia multi-remoto, roadmap NV1)
AI_REMOTE2_BASE_URL=https://integrate.api.nvidia.com/v1
AI_REMOTE2_API_KEY=
AI_REMOTE2_MODEL_FAST=z-ai/glm-5.2
AI_REMOTE2_MODEL_ADVANCED=z-ai/glm-5.2

# Busca web (fonte A de anúncios) — free tier 2k/mês
BRAVE_API_KEY=

# Token interno das rotas de escrita (ingerir/varrer/extrair/requalificar por API)
MOTOR_TOKEN=

# Painel do corretor (SEG-01/05): SEM senha aqui o painel NEM EXISTE (404).
# PAINEL_SECRET mantém as sessões válidas entre deploys (opcional).
PAINEL_SENHA=
PAINEL_SECRET=

# Corretor Inteligente OS — nome da organização padrão usada somente na alpha de usuário único.
# Autenticação individual substituirá esta ponte antes do uso comercial multiusuário.
OS_ORG_NAME=Corretor Inteligente

# Assistente privado. Produção recomendada: app -> Hermes em loopback -> Kimi Code.
# A chave Kimi fica no perfil isolado do Hermes, não neste processo do motor.
AGENT_RUNTIME=local
AGENT_TIMEOUT_MS=180000
AGENT_LOCAL_FALLBACK=true
HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=
HERMES_MODEL=hermes-agent

# Saída de emergência explícita. Mantida desligada por padrão para não amarrar o produto
# à interpretação dos termos da assinatura. O alias kimi-for-coding recebe upgrades do backend.
KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1
KIMI_CODE_API_KEY=
KIMI_CODE_MODEL=k3
KIMI_CODE_MODEL_HIGH_SPEED=kimi-for-coding-highspeed
KIMI_CODE_ALLOW_DIRECT_PRODUCT=false
