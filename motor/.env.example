# SEG-07: espelho do /opt/radar/api/.env — documenta as variáveis SEM os valores.
# O .env real vive só no servidor (chmod 640, dono www-data) e NUNCA entra no git.

# PostgreSQL local do VPS (usuário/senha em /root/radar-info.txt)
DATABASE_URL=postgres://radar:SENHA@localhost:5432/radar

# IA local (base eterna e fallback) — Ollama no próprio VPS
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434
AI_MODEL_FAST=qwen3:8b
AI_MODEL_ADVANCED=qwen3:14b
# AI_LOCAL_ENABLED=false tira o Ollama da cadeia SEM desinstalar nada — use quando o
# remoto estiver configurado e quiser aposentar a inferência local (CPU/RAM do VPS).
AI_LOCAL_ENABLED=true

# IA remota opcional (cadeia liga sozinha se a chave existir) — Groq/NVIDIA Build etc.
# 19/07/2026: qwen3-32b foi APOSENTADO pela Groq (404) e travava o degrau 1 da cadeia.
# LIÇÃO: o degrau FAST precisa aceitar response_format json_object — qwen3.6-27b
# (raciocínio) falha a validação JSON da Groq; llama-3.1-8b-instant extrai em ~2 s
# (provado em produção 19/07: 12 ok em 2 min). Testar SEMPRE com o modo JSON, não
# com chamada solta.
# ATENÇÃO (incidente 22/07): sem estas chaves PREENCHIDAS a cadeia é só o Ollama —
# se ele parar, TODA extração falha. Conferir com: grep -c 'AI_REMOTE_API_KEY=gsk_' .env
AI_REMOTE_BASE_URL=https://api.groq.com/openai/v1
AI_REMOTE_API_KEY=
AI_REMOTE_MODEL_FAST=llama-3.1-8b-instant
AI_REMOTE_MODEL_ADVANCED=llama-3.3-70b-versatile

# IA remota degrau 2 (NVIDIA Build free endpoint — cadeia multi-remoto, roadmap NV1)
# PROVADO 22/07/2026: z-ai/glm-5.2 existe no catálogo (é o único GLM) e responde com
# response_format json_object (teste direto na API com a chave de produção). As falhas
# de 22/07 foram 429 (cota compartilhada do free tier, ~40 RPM) com varredura +
# reextração rodando EM PARALELO — regra operacional: nada de lote manual de IA
# durante os turnos agendados (03:30-06:30).
AI_REMOTE2_BASE_URL=https://integrate.api.nvidia.com/v1
AI_REMOTE2_API_KEY=
AI_REMOTE2_MODEL_FAST=z-ai/glm-5.2
AI_REMOTE2_MODEL_ADVANCED=z-ai/glm-5.2

# Busca web (fonte A de anúncios) — CADEIA (21/07/2026): Google CSE primário + Brave reserva.
# Degrau 1 — Google Custom Search: GRÁTIS 100 buscas/DIA (~3.000/mês), SEM cartão.
#   Criar (5 min): console.cloud.google.com → projeto novo → ativar "Custom Search API"
#   → Credenciais → chave de API (= GOOGLE_CSE_KEY). Depois:
#   programmablesearchengine.google.com → criar mecanismo → "Pesquisar em toda a web" LIGADO
#   → copiar o ID do mecanismo (= GOOGLE_CSE_CX). Cota diária renova à meia-noite (Pacífico).
# Degrau 2 — Brave: free 2k/mês (renova dia 1º). Cota estourada = cooldown e a cadeia desce;
#   sem GOOGLE_CSE_*, a cadeia opera só com o Brave.
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
BRAVE_API_KEY=

# Token interno das rotas de escrita (ingerir/varrer/extrair/requalificar por API)
MOTOR_TOKEN=

# Painel do corretor (SEG-01/05): SEM senha aqui o painel NEM EXISTE (404).
# PAINEL_SECRET mantém as sessões válidas entre deploys (opcional).
PAINEL_SENHA=
PAINEL_SECRET=

# Corretor Inteligente OS — nome da organização padrão usada somente na alpha de usuário único.
# Autenticação individual substituirá esta ponte antes do uso comercial multiusuário.
OS_ORG_NAME=Corretor Inteligente

# Assistente privado. Produção recomendada: app -> Hermes em loopback -> Kimi Code.
# A chave Kimi fica no perfil isolado do Hermes, não neste processo do motor.
AGENT_RUNTIME=local
AGENT_TIMEOUT_MS=180000
AGENT_LOCAL_FALLBACK=true
AGENT_DOCUMENT_ROOT=/opt/radar/data/documents
HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=
HERMES_MODEL=hermes-agent

# Orquestração assíncrona K3/Hermes. O timer diário usa no máximo estas consultas
# adicionais e grava somente evidências/hipóteses para revisão.
INTELLIGENCE_QUERY_BUDGET=4
INTELLIGENCE_RESULT_BUDGET=40
INTELLIGENCE_BATCH_SIZE=20
INTELLIGENCE_TIMEOUT_MS=300000

# Saída de emergência explícita. Mantida desligada por padrão para não amarrar o produto
# à interpretação dos termos da assinatura. O alias kimi-for-coding recebe upgrades do backend.
KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1
KIMI_CODE_API_KEY=
KIMI_CODE_MODEL=k3
KIMI_CODE_MODEL_HIGH_SPEED=kimi-for-coding-highspeed
KIMI_CODE_ALLOW_DIRECT_PRODUCT=false
